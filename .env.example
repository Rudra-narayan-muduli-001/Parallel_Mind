# ---- OpenAI ----
OPENAI_API_KEYS=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ---- Anthropic ----
ANTHROPIC_API_KEYS=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ---- Groq ----
GROQ_API_KEYS=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=openai/gpt-oss-120b

# ---- OpenRouter ----
OPENROUTER_API_KEYS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# ---- Ollama Cloud ----
OLLAMA_CLOUD_API_KEYS=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_DEFAULT_MODEL=nemotron-3-super

# ---- NVIDIA NIM ----
NVIDIA_NIM_API_KEYS=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_DEFAULT_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# ---- OpenCode Zen ----
OPENCODE_ZEN_API_KEYS=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_ZEN_DEFAULT_MODEL=big-pickle

# ---- Orchestration ----
DEFAULT_MAX_CONCURRENCY=5
DEFAULT_TIMEOUT_SEC=60
CIRCUIT_BREAKER_FAIL_THRESHOLD=5
CIRCUIT_BREAKER_RESET_SEC=60

# ---- Routing ----
ROUTING_MODE=rule_based
ROUTER_MODEL_PROVIDER=groq
ROUTER_MODEL_NAME=openai/gpt-oss-120b

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json